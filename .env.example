# Copy to .env for local dev (api/main.py loads it via python-dotenv).
# In Railway, set these as service variables instead — do not commit a real .env.

ANTHROPIC_API_KEY=

QBO_CLIENT_ID=         # from Intuit Developer Portal
QBO_CLIENT_SECRET=     # from Intuit Developer Portal
QBO_REDIRECT_URI=      # must match portal config; must be SaaS domain in prod

FERNET_KEY=            # generated: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

DATABASE_URL=          # Railway PostgreSQL connection string
SESSION_SECRET=        # random 32-byte hex string, e.g.: python -c "import secrets; print(secrets.token_hex(32))"

# Not in the original checklist but required by api/main.py — CORS origin
# and the OAuth callback redirect target. Defaults to http://localhost:5173
# if unset, which is only correct for local dev.
FRONTEND_URL=
